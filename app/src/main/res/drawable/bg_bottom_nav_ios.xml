<?xml version="1.0" encoding="utf-8"?>
<!-- Floating iOS-style tab bar container -->
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/ios_card_background" />
            <corners android:radius="28dp" />
            <stroke
                android:width="1dp"
                android:color="@color/ios_divider" />
        </shape>
    </item>
</layer-list>
