<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Gradient Header Background for Patient Dashboard (Green/Teal) -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:angle="135"
        android:startColor="#34C759"
        android:endColor="#30B7B0"
        android:type="linear"/>
    <corners
        android:bottomLeftRadius="32dp"
        android:bottomRightRadius="32dp"/>
</shape>
