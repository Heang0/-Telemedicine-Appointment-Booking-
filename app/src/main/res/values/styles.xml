<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- AppBarOverlay -->
    <style name="Theme.Telemedicine.AppBarOverlay" parent="ThemeOverlay.AppCompat.Dark.ActionBar" />

    <!-- PopupOverlay -->
    <style name="Theme.Telemedicine.PopupOverlay" parent="ThemeOverlay.AppCompat.Light" />

    <!-- Legacy Button style (for compatibility) -->
    <style name="Widget.Telemedicine.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/ios_blue</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Clean Button style (for compatibility) -->
    <style name="Widget.Telemedicine.Clean.Button" parent="Widget.Material3.Button">
        <item name="android:textColor">@color/white</item>
        <item name="backgroundTint">@color/ios_blue</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:textAllCaps">false</item>
    </style>
</resources>
