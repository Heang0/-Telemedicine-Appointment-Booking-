<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    tools:context=".AdminDashboardActivity">

    <!-- AI Assistant Floating Button -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_ai_assistant"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_margin="24dp"
        android:src="@drawable/ic_ai_assistant"
        android:contentDescription="AI Health Assistant"
        app:backgroundTint="@color/ai_blue_primary"
        app:tint="@color/text_on_surface"
        app:shapeAppearanceOverlay="@style/ShapeAppearance.Material3.Corner.Full"
        app:layout_anchorGravity="bottom|end"
        app:elevation="4dp" />

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="100dp" />

    <!-- iOS-style Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_navigation"
        android:layout_width="340dp"
        android:layout_height="76dp"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_bottom_nav_ios"
        android:paddingHorizontal="8dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:elevation="0dp"
        app:elevation="0dp"
        app:itemIconSize="28dp"
        app:itemIconTint="@color/bottom_nav_icon_color_ios"
        app:itemBackground="@drawable/bg_bottom_nav_item_ios"
        app:itemTextColor="@android:color/transparent"
        app:itemHorizontalTranslationEnabled="false"
        app:labelVisibilityMode="unlabeled"
        app:menu="@menu/admin_bottom_nav_menu" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
