<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/ios_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ios_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row: Patient Name + Status -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/text_patient_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="John Smith"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"/>

            <TextView
                android:id="@+id/text_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Scheduled"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="@color/ios_blue"
                android:background="@drawable/bg_status_badge"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>

        </LinearLayout>

        <!-- Appointment Type -->
        <TextView
            android:id="@+id/text_appointment_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="In-Person Visit"
            android:textSize="14sp"
            android:textColor="@color/ios_text_secondary"
            android:layout_marginTop="8dp"/>

        <!-- Date Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="12dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_calendar"
                app:tint="@color/ios_text_secondary"/>

            <TextView
                android:id="@+id/text_date"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="January 15, 2024"
                android:textSize="14sp"
                android:textColor="@color/ios_text_primary"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Time Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_access_time_24"
                app:tint="@color/ios_text_secondary"/>

            <TextView
                android:id="@+id/text_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="10:30 AM"
                android:textSize="14sp"
                android:textColor="@color/ios_text_primary"
                android:layout_marginStart="8dp"/>

        </LinearLayout>

        <!-- Reason -->
        <TextView
            android:id="@+id/text_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Annual checkup"
            android:textSize="13sp"
            android:textColor="@color/ios_text_secondary"
            android:layout_marginTop="12dp"
            android:ellipsize="end"
            android:maxLines="2"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
