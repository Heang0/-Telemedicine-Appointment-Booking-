<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="24dp"
            android:paddingTop="48dp"
            android:paddingBottom="32dp">

            <!-- Header Section with Logo - SAME AS LOGIN -->
            <LinearLayout
                android:id="@+id/layout_header"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <!-- Your Custom Logo -->
                <ImageView
                    android:id="@+id/image_logo"
                    android:layout_width="120dp"
                    android:layout_height="120dp"
                    android:src="@drawable/logo"
                    android:contentDescription="App Logo"
                    android:scaleType="fitCenter"/>

                <!-- App Title -->
                <TextView
                    android:id="@+id/text_app_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Telemedicine"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"
                    android:letterSpacing="-0.02"
                    android:layout_marginTop="20dp"/>

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/text_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your health, simplified"
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

            <!-- Welcome Text - Different Title -->
            <TextView
                android:id="@+id/text_welcome"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Create Account"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                app:layout_constraintTop_toBottomOf="@id/layout_header"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="16dp"/>

            <TextView
                android:id="@+id/text_welcome_subtitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Sign up to get started with your health journey"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toBottomOf="@id/text_welcome"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="4dp"/>

            <!-- Google Sign-Up Button - SAME STYLE AS LOGIN -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_google_sign_up"
                android:layout_width="0dp"
                android:layout_height="56dp"
                android:text="Sign up with Google"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:textColor="@color/google_button_text"
                app:backgroundTint="@color/google_button_background"
                app:cornerRadius="14dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                app:icon="@drawable/ic_google_logo"
                app:iconGravity="textStart"
                app:iconTint="@null"
                app:iconPadding="12dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/text_welcome_subtitle"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:letterSpacing="0.02"/>

            <!-- Divider with "Or" - SAME AS LOGIN -->
            <LinearLayout
                android:id="@+id/layout_divider"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@id/btn_google_sign_up"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="or continue with email"
                    android:textSize="13sp"
                    android:textColor="@color/text_tertiary"
                    android:paddingHorizontal="16dp"/>

                <View
                    android:layout_width="0dp"
                    android:layout_height="1dp"
                    android:layout_weight="1"
                    android:background="@color/divider"/>

            </LinearLayout>

            <!-- Registration Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_form"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="1dp"
                android:layout_marginTop="24dp"
                app:layout_constraintTop_toBottomOf="@id/layout_divider"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="24dp">

                    <!-- Full Name Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_full_name"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Full Name"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@drawable/ic_person_24"
                        app:startIconTint="@color/text_tertiary"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_full_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Email Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_email"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Email"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@drawable/ic_baseline_email_24"
                        app:startIconTint="@color/text_tertiary"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Password"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@drawable/ic_baseline_lock_24"
                        app:startIconTint="@color/text_tertiary"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/text_tertiary"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Confirm Password Input -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:id="@+id/layout_confirm_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Confirm Password"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@drawable/ic_baseline_lock_24"
                        app:startIconTint="@color/text_tertiary"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/text_tertiary"
                        android:layout_marginTop="16dp"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_confirm_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Terms and Conditions Checkbox -->
                    <com.google.android.material.checkbox.MaterialCheckBox
                        android:id="@+id/checkbox_terms"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="I agree to the Terms of Service and Privacy Policy"
                        android:textSize="13sp"
                        android:textColor="@color/text_secondary"
                        android:buttonTint="@color/primary"
                        android:layout_marginTop="16dp"/>

                    <!-- Register Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_register"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Create Account"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        app:backgroundTint="@color/primary"
                        app:cornerRadius="14dp"
                        android:layout_marginTop="16dp"
                        android:letterSpacing="0.02"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Login Link -->
            <LinearLayout
                android:id="@+id/layout_login"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                app:layout_constraintTop_toBottomOf="@id/card_form"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_marginTop="24dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Already have an account? "
                    android:textSize="15sp"
                    android:textColor="@color/text_secondary"/>

                <TextView
                    android:id="@+id/text_login"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Log In"
                    android:textSize="15sp"
                    android:textColor="@color/primary"
                    android:textStyle="bold"/>

            </LinearLayout>

            <!-- Bottom Spacer -->
            <View
                android:layout_width="0dp"
                android:layout_height="32dp"
                app:layout_constraintTop_toBottomOf="@id/layout_login"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.core.widget.NestedScrollView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
