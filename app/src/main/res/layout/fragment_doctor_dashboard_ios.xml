<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Doctor Dashboard - Modern Apple Health App Inspired Design -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- iOS-Style Header with Gradient -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ios_gradient_header">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingStart="@dimen/ios_page_horizontal_padding"
                android:paddingEnd="@dimen/ios_page_horizontal_padding"
                android:paddingTop="@dimen/ios_header_top_padding"
                android:paddingBottom="@dimen/ios_header_bottom_padding">

                <!-- Header Row: Greeting + Profile -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good Morning"
                            android:textSize="15sp"
                            android:textColor="@color/white"
                            android:alpha="0.85"
                            android:fontFamily="sans-serif-medium"/>

                        <TextView
                            android:id="@+id/text_doctor_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Dr. Smith"
                            android:textSize="@dimen/ios_header_name_size"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif"
                            android:letterSpacing="-0.02"
                            android:maxLines="1"
                            android:ellipsize="end"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cardiologist • MD"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:alpha="0.75"
                            android:layout_marginTop="6dp"/>

                    </LinearLayout>

                    <!-- Profile Avatar with Ring -->
                    <FrameLayout
                        android:layout_width="64dp"
                        android:layout_height="64dp">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/profile_image"
                            android:layout_width="64dp"
                            android:layout_height="64dp"
                            android:src="@drawable/ic_doctor_avatar"
                            app:civ_border_width="3dp"
                            app:civ_border_color="@color/white"/>

                        <!-- Online Status Indicator -->
                        <View
                            android:layout_width="18dp"
                            android:layout_height="18dp"
                            android:background="@drawable/bg_online_status"
                            android:layout_gravity="bottom|end"/>

                    </FrameLayout>

                </LinearLayout>

                <!-- iOS-Style Stats Pills -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="24dp"
                    android:weightSum="3">

                    <!-- Today's Patients -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_ios_stat_pill_transparent"
                        android:padding="14dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/text_appointments_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="8"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-light"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:alpha="0.8"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Total Patients -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_ios_stat_pill_transparent"
                        android:padding="14dp"
                        android:gravity="center">

                        <TextView
                            android:id="@+id/text_patients_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="156"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:fontFamily="sans-serif-light"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Patients"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:alpha="0.8"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Unread Messages -->
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        android:background="@drawable/bg_ios_stat_pill_transparent"
                        android:padding="14dp"
                        android:gravity="center">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <TextView
                                android:id="@+id/text_messages_count"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="5"
                                android:textSize="28sp"
                                android:textStyle="bold"
                                android:textColor="@color/white"
                                android:fontFamily="sans-serif-light"/>

                            <!-- Red Badge for Unread -->
                            <TextView
                                android:layout_width="20dp"
                                android:layout_height="20dp"
                                android:background="@drawable/bg_notification_badge"
                                android:text="5"
                                android:textSize="11sp"
                                android:textColor="@color/white"
                                android:gravity="center"
                                android:fontFamily="sans-serif-bold"
                                android:layout_marginStart="24dp"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unread"
                            android:textSize="12sp"
                            android:textColor="@color/white"
                            android:alpha="0.8"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </LinearLayout>

            </LinearLayout>

        </FrameLayout>

        <!-- Main Content Container -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/ios_page_horizontal_padding"
            android:paddingEnd="@dimen/ios_page_horizontal_padding"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Primary Action Button - iOS Style -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/chip_new_appointment"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Schedule New Appointment"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@color/ios_blue"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_add"
                app:iconGravity="textStart"
                app:iconPadding="12dp"
                app:iconSize="22dp"
                app:iconTint="@color/white"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.01"
                android:elevation="0dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"/>

            <!-- Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="@dimen/ios_section_title_size"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01"
                android:layout_marginTop="28dp"
                android:layout_marginBottom="16dp"/>

            <!-- iOS-Style Action Cards Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignMargins">

                <!-- Patients Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chip_patients"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="start|top">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_container_blue">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_profile"
                                android:layout_gravity="center"
                                app:tint="@color/ios_blue"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="My Patients"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="14dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="View all patients"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="@color/ios_blue"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Messages Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chip_messages"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="start|top">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_container_purple">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_chat"
                                android:layout_gravity="center"
                                app:tint="#AF52ED"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Messages"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="14dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Patient consultations"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="#AF52ED"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Prescriptions Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chip_prescriptions"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="start|top">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_container_orange">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_prescription"
                                android:layout_gravity="center"
                                app:tint="@color/ios_orange"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Prescriptions"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="14dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Create new Rx"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="@color/ios_orange"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Lab Results Card -->
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/chip_lab_results"
                    android:layout_width="0dp"
                    android:layout_height="150dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="10dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="18dp"
                        android:gravity="start|top">

                        <FrameLayout
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:background="@drawable/bg_icon_container_teal">

                            <ImageView
                                android:layout_width="26dp"
                                android:layout_height="26dp"
                                android:src="@drawable/ic_lab_results"
                                android:layout_gravity="center"
                                app:tint="#30B7B0"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Medical Records"
                            android:textSize="17sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="14dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Open patient EMR"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif"
                            android:layout_marginTop="4dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="›"
                            android:textSize="20sp"
                            android:textColor="#30B7B0"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

            <!-- Today's Appointments Section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="12dp"
                android:layout_marginBottom="14dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Today's Schedule"
                    android:textSize="@dimen/ios_section_title_size"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="-0.01"/>

                <TextView
                    android:id="@+id/text_see_all_appointments"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="See All"
                    android:textSize="16sp"
                    android:textColor="@color/ios_blue"
                    android:textStyle="bold"
                    android:fontFamily="sans-serif-medium"/>

            </LinearLayout>

            <!-- Appointments List Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_appointments"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:padding="4dp"
                    android:clipToPadding="false"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Today's Summary Stats -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Today's Summary"
                android:textSize="@dimen/ios_section_title_size"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:fontFamily="sans-serif"
                android:letterSpacing="-0.01"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="14dp"/>

            <!-- Summary Stats Grid -->
            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:rowCount="2"
                android:alignmentMode="alignMargins">

                <!-- Completed Consultations -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_check_circle_24"
                            app:tint="@color/ios_green"/>

                        <TextView
                            android:id="@+id/text_today_patients_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="5"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Completed"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Pending Prescriptions -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="10dp"
                    android:layout_marginBottom="12dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_medication_24"
                            app:tint="@color/ios_orange"/>

                        <TextView
                            android:id="@+id/text_pending_prescriptions_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="2"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending Rx"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Unread Messages -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_marginEnd="10dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_chat_bubble_24"
                            app:tint="@color/ios_blue"/>

                        <TextView
                            android:id="@+id/text_unread_messages_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="3"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-light"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Unread"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Availability Status -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="120dp"
                    android:layout_columnWeight="1"
                    android:layout_marginStart="10dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="18dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="1dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center">

                        <FrameLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content">

                            <ImageView
                                android:layout_width="32dp"
                                android:layout_height="32dp"
                                android:src="@drawable/ic_check_circle_24"
                                app:tint="@color/ios_green"/>

                            <View
                                android:layout_width="12dp"
                                android:layout_height="12dp"
                                android:background="@drawable/bg_online_status"
                                android:layout_gravity="end"/>

                        </FrameLayout>

                        <TextView
                            android:id="@+id/text_availability_value"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Online"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Available"
                            android:textSize="13sp"
                            android:textColor="@color/ios_text_secondary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </GridLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
