<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Profile Fragment -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- iOS-Style Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ios_gradient_header">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="56dp"
                android:gravity="center_horizontal">

                <!-- Profile Image -->
                <de.hdodenhof.circleimageview.CircleImageView
                    android:id="@+id/profile_image"
                    android:layout_width="100dp"
                    android:layout_height="100dp"
                    android:src="@drawable/ic_profile"
                    app:civ_border_width="4dp"
                    app:civ_border_color="@color/white"/>

                <!-- User Name -->
                <TextView
                    android:id="@+id/text_user_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="John Doe"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="-0.02"
                    android:layout_marginTop="16dp"/>

                <!-- User Email -->
                <TextView
                    android:id="@+id/text_user_email"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="john.doe@example.com"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:alpha="0.85"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="4dp"/>

                <!-- User Role Badge -->
                <TextView
                    android:id="@+id/text_user_role"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:background="@drawable/bg_ios_stat_pill_transparent"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="8dp"
                    android:layout_marginTop="14dp"/>

            </LinearLayout>

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="24dp"
            android:paddingBottom="24dp">

            <!-- Account Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Account"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:layout_marginBottom="12dp"/>

            <!-- Account Settings Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <!-- Edit Profile -->
                    <LinearLayout
                        android:id="@+id/layout_edit_profile"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:background="@drawable/bg_ios_list_item">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_container_blue">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_profile"
                                android:layout_gravity="center"
                                app:tint="@color/ios_blue"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Edit Profile"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="@color/ios_text_tertiary"
                            android:alpha="0.5"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ios_divider"
                        android:layout_marginStart="70dp"/>

                    <!-- Notifications -->
                    <LinearLayout
                        android:id="@+id/layout_notifications"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:background="@drawable/bg_ios_list_item">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_container_orange">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_notifications"
                                android:layout_gravity="center"
                                app:tint="@color/ios_orange"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Notifications"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/switch_notifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:checked="true"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ios_divider"
                        android:layout_marginStart="70dp"/>

                    <!-- Privacy -->
                    <LinearLayout
                        android:id="@+id/layout_privacy"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:background="@drawable/bg_ios_list_item">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_container_green">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_baseline_lock_24"
                                android:layout_gravity="center"
                                app:tint="@color/ios_green"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Privacy"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="@color/ios_text_tertiary"
                            android:alpha="0.5"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Support Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Support"
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_secondary"
                android:textAllCaps="true"
                android:letterSpacing="0.05"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="12dp"/>

            <!-- Support Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:paddingVertical="8dp">

                    <!-- Help Center -->
                    <LinearLayout
                        android:id="@+id/layout_help"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:background="@drawable/bg_ios_list_item">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_container_blue">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_help"
                                android:layout_gravity="center"
                                app:tint="@color/ios_blue"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Help Center"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="@color/ios_text_tertiary"
                            android:alpha="0.5"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ios_divider"
                        android:layout_marginStart="70dp"/>

                    <!-- Contact Us -->
                    <LinearLayout
                        android:id="@+id/layout_contact"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="16dp"
                        android:background="@drawable/bg_ios_list_item">

                        <FrameLayout
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:background="@drawable/bg_icon_container_green">

                            <ImageView
                                android:layout_width="22dp"
                                android:layout_height="22dp"
                                android:src="@drawable/ic_baseline_email_24"
                                android:layout_gravity="center"
                                app:tint="@color/ios_green"/>

                        </FrameLayout>

                        <TextView
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Contact Us"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="14dp"/>

                        <ImageView
                            android:layout_width="20dp"
                            android:layout_height="20dp"
                            android:src="@drawable/ic_arrow_forward"
                            app:tint="@color/ios_text_tertiary"
                            android:alpha="0.5"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Log Out"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:layout_marginTop="28dp"
                app:backgroundTint="@color/ios_red"
                app:cornerRadius="14dp"
                app:icon="@drawable/ic_logout"
                app:iconGravity="textStart"
                app:iconTint="@color/white"
                app:iconSize="22dp"
                android:fontFamily="sans-serif-medium"/>

            <!-- App Version -->
            <TextView
                android:id="@+id/text_app_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Version 1.0.0"
                android:textSize="13sp"
                android:textColor="@color/ios_text_tertiary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="20dp"
                android:layout_gravity="center"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
