<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Patient List Item -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/ios_card_background"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ios_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <!-- Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/image_patient_avatar"
            android:layout_width="52dp"
            android:layout_height="52dp"
            android:src="@drawable/ic_profile"
            app:civ_border_width="2dp"
            app:civ_border_color="@color/ios_divider"/>

        <!-- Patient Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="14dp">

            <TextView
                android:id="@+id/text_patient_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Name"
                android:textSize="17sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:fontFamily="sans-serif-medium"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="4dp">

                <TextView
                    android:id="@+id/text_patient_condition"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Condition"
                    android:textSize="13sp"
                    android:textColor="@color/ios_text_secondary"
                    android:fontFamily="sans-serif"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text=" • "
                    android:textSize="13sp"
                    android:textColor="@color/ios_text_secondary"/>

                <TextView
                    android:id="@+id/text_last_visit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Last: Jan 15"
                    android:textSize="13sp"
                    android:textColor="@color/ios_text_secondary"
                    android:fontFamily="sans-serif"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Action Arrow -->
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_forward"
            app:tint="@color/ios_text_secondary"
            android:alpha="0.5"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
