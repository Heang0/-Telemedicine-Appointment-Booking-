<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Appointment Details -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- iOS-Style Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ios_gradient_header">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="56dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Appointment Details"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="-0.02"/>

                <TextView
                    android:id="@+id/text_appointment_status_header"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Scheduled"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:alpha="0.85"
                    android:layout_marginTop="6dp"/>

            </LinearLayout>

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:layout_marginTop="-20dp">

            <!-- Patient & Doctor Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Patient Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/image_patient"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_profile"
                            app:civ_border_width="2dp"
                            app:civ_border_color="@color/ios_blue"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Patient"
                                android:textSize="12sp"
                                android:textColor="@color/ios_text_secondary"/>

                            <TextView
                                android:id="@+id/text_patient_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="John Doe"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/ios_text_primary"
                                android:fontFamily="sans-serif-medium"/>

                        </LinearLayout>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ios_divider"
                        android:layout_marginVertical="16dp"/>

                    <!-- Doctor Info -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/image_doctor"
                            android:layout_width="50dp"
                            android:layout_height="50dp"
                            android:src="@drawable/ic_doctor_avatar"
                            app:civ_border_width="2dp"
                            app:civ_border_color="@color/ios_green"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="14dp">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Doctor"
                                android:textSize="12sp"
                                android:textColor="@color/ios_text_secondary"/>

                            <TextView
                                android:id="@+id/text_doctor_name"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dr. Jane Smith"
                                android:textSize="17sp"
                                android:textStyle="bold"
                                android:textColor="@color/ios_text_primary"
                                android:fontFamily="sans-serif-medium"/>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Date & Time Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Date &amp; Time"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_text_secondary"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_calendar"
                            app:tint="@color/ios_blue"/>

                        <TextView
                            android:id="@+id/text_appointment_date"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Jan 15, 2023 at 10:30 AM"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="12dp"/>

                    </LinearLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Appointment Type & Reason -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Appointment Type"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_text_secondary"
                        android:layout_marginBottom="12dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="24dp"
                            android:layout_height="24dp"
                            android:src="@drawable/ic_video_call_24"
                            app:tint="@color/ios_blue"/>

                        <TextView
                            android:id="@+id/text_appointment_type"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:text="Video Call"
                            android:textSize="16sp"
                            android:textColor="@color/ios_text_primary"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="12dp"/>

                    </LinearLayout>

                    <!-- Divider -->
                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:background="@color/ios_divider"
                        android:layout_marginVertical="16dp"/>

                    <!-- Reason -->
                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Reason for Visit"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_text_secondary"
                        android:layout_marginBottom="8dp"/>

                    <TextView
                        android:id="@+id/text_reason"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="Annual checkup"
                        android:textSize="15sp"
                        android:textColor="@color/ios_text_primary"
                        android:fontFamily="sans-serif"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="24dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_complete_appointment"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Complete"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/ios_green"
                    app:cornerRadius="14dp"
                    android:layout_marginEnd="8dp"
                    app:icon="@drawable/ic_check_circle_24"
                    app:iconGravity="textStart"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_cancel_appointment"
                    android:layout_width="0dp"
                    android:layout_height="56dp"
                    android:layout_weight="1"
                    android:text="Cancel"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/ios_card_background"
                    app:strokeColor="@color/ios_red"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_call_end"
                    app:iconGravity="textStart"
                    app:iconTint="@color/ios_red"/>

            </LinearLayout>

            <!-- Back Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_back"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Back to Dashboard"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="@color/ios_system_fill"
                app:cornerRadius="14dp"
                android:layout_marginTop="12dp"
                app:icon="@drawable/ic_arrow_back"
                app:iconGravity="textStart"
                app:iconTint="@color/ios_text_primary"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
