<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    android:fillViewport="true">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="20dp"
        android:paddingTop="8dp"
        android:paddingBottom="24dp">

        <!-- Welcome Section -->
        <LinearLayout
            android:id="@+id/layout_welcome"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/text_welcome_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Admin Dashboard"
                android:textSize="15sp"
                android:textColor="@color/ios_text_secondary"/>

            <TextView
                android:id="@+id/text_admin_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Platform Management"
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:letterSpacing="-0.02"
                android:layout_marginTop="4dp"/>

        </LinearLayout>

        <!-- Quick Actions Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_quick_actions"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ios_card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ios_divider"
            app:strokeWidth="0dp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/layout_welcome"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:padding="20dp">

                <!-- User Management -->
                <LinearLayout
                    android:id="@+id/chip_user_management"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/chip_audit_logs"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintHorizontal_weight="1">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_permissions"
                        android:padding="12dp"
                        android:background="@drawable/bg_action_button"
                        app:tint="@color/white"
                        android:contentDescription="User Management"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Users"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_primary"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Audit Logs -->
                <LinearLayout
                    android:id="@+id/chip_audit_logs"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/chip_user_management"
                    app:layout_constraintEnd_toStartOf="@id/chip_analytics"
                    app:layout_constraintHorizontal_weight="1">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_audit_logs"
                        android:padding="12dp"
                        android:background="@drawable/bg_action_button_green"
                        app:tint="@color/white"
                        android:contentDescription="Audit Logs"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Audits"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_primary"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Analytics -->
                <LinearLayout
                    android:id="@+id/chip_analytics"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintStart_toEndOf="@id/chip_audit_logs"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_analytics"
                        android:padding="12dp"
                        android:background="@drawable/bg_action_button_purple"
                        app:tint="@color/white"
                        android:contentDescription="Analytics"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Analytics"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_primary"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Partner Portal -->
                <LinearLayout
                    android:id="@+id/chip_partner_portal"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/chip_user_management"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toStartOf="@id/chip_settings"
                    app:layout_constraintHorizontal_chainStyle="spread"
                    app:layout_constraintHorizontal_weight="1">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_partner_portal"
                        android:padding="12dp"
                        android:background="@drawable/bg_action_button_orange"
                        app:tint="@color/white"
                        android:contentDescription="Partner Portal"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Partners"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_primary"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"/>

                </LinearLayout>

                <!-- Settings -->
                <LinearLayout
                    android:id="@+id/chip_settings"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:padding="12dp"
                    android:layout_marginTop="16dp"
                    app:layout_constraintTop_toBottomOf="@id/chip_audit_logs"
                    app:layout_constraintStart_toEndOf="@id/chip_partner_portal"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_weight="1">

                    <ImageView
                        android:layout_width="48dp"
                        android:layout_height="48dp"
                        android:src="@drawable/ic_settings"
                        android:padding="12dp"
                        android:background="@drawable/bg_action_button_gray"
                        app:tint="@color/white"
                        android:contentDescription="Settings"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Settings"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_primary"
                        android:layout_marginTop="8dp"
                        android:textStyle="bold"/>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Platform Stats -->
        <TextView
            android:id="@+id/text_platform_stats_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Platform Overview"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary"
            android:letterSpacing="-0.01"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/card_quick_actions"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Stats Grid -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_platform_stats"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ios_card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ios_divider"
            app:strokeWidth="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/text_platform_stats_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <GridLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:columnCount="2"
                android:padding="4dp">

                <!-- Total Users -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_margin="2dp">

                    <TextView
                        android:id="@+id/text_total_users"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_blue"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Total Users"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_secondary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Active Doctors -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_margin="2dp"
                    android:background="@color/ios_system_fill">

                    <TextView
                        android:id="@+id/text_active_doctors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_green"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Doctors"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_secondary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Appointments Today -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_margin="2dp">

                    <TextView
                        android:id="@+id/text_appointments_today"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_orange"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Today's Appts"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_secondary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

                <!-- Pending Verifications -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_columnWeight="1"
                    android:orientation="vertical"
                    android:padding="20dp"
                    android:layout_margin="2dp"
                    android:background="@color/ios_system_fill">

                    <TextView
                        android:id="@+id/text_pending_verifications"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="0"
                        android:textSize="28sp"
                        android:textStyle="bold"
                        android:textColor="@color/ios_red"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pending"
                        android:textSize="13sp"
                        android:textColor="@color/ios_text_secondary"
                        android:layout_marginTop="4dp"/>

                </LinearLayout>

            </GridLayout>

        </com.google.android.material.card.MaterialCardView>

        <!-- Recent Activity Section -->
        <TextView
            android:id="@+id/text_recent_activity_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Recent Activity"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary"
            android:letterSpacing="-0.01"
            android:layout_marginTop="28dp"
            app:layout_constraintTop_toBottomOf="@id/card_platform_stats"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Activity List Card -->
        <com.google.android.material.card.MaterialCardView
            android:id="@+id/card_recent_activity"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/ios_card_background"
            app:cardCornerRadius="20dp"
            app:cardElevation="0dp"
            app:strokeColor="@color/ios_divider"
            app:strokeWidth="0dp"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/text_recent_activity_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_recent_activity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:overScrollMode="never"/>

        </com.google.android.material.card.MaterialCardView>

        <!-- Bottom Spacer -->
        <View
            android:layout_width="0dp"
            android:layout_height="24dp"
            app:layout_constraintTop_toBottomOf="@id/card_recent_activity"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.core.widget.NestedScrollView>
