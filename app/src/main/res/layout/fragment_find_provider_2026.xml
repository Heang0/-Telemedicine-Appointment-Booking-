<?xml version="1.0" encoding="utf-8"?>
<!-- 2026 Modern Find Provider Fragment -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/background"
        android:elevation="0dp">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            android:background="@color/background"
            app:title="Find Providers"
            app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge"
            app:titleTextColor="@color/text_primary"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Search Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="16dp"
                app:cardBackgroundColor="@color/surface"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeColor="@color/divider"
                app:strokeWidth="0dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="16dp">

                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Search doctors, specialties..."
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/primary"
                        app:boxStrokeWidth="1dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:startIconDrawable="@drawable/ic_search"
                        app:startIconTint="@color/text_tertiary"
                        style="@style/Widget.Material3.TextInputLayout.OutlinedBox">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_search"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textSize="16sp"
                            android:textColor="@color/text_primary"/>

                    </com.google.android.material.textfield.TextInputLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Specialty Filter Chips -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Specialties"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="12dp"/>

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:scrollbars="none"
                android:paddingHorizontal="20dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_all_specialties"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="All"
                        android:textSize="13sp"
                        app:chipBackgroundColor="@color/primary"
                        android:textColor="@color/white"
                        app:chipCornerRadius="20dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_cardiology"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cardiology"
                        android:textSize="13sp"
                        app:chipBackgroundColor="@color/surface_variant"
                        android:textColor="@color/text_secondary"
                        app:chipCornerRadius="20dp"
                        app:chipStrokeColor="@color/divider"
                        app:chipStrokeWidth="1dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_pediatrics"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pediatrics"
                        android:textSize="13sp"
                        app:chipBackgroundColor="@color/surface_variant"
                        android:textColor="@color/text_secondary"
                        app:chipCornerRadius="20dp"
                        app:chipStrokeColor="@color/divider"
                        app:chipStrokeWidth="1dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_dermatology"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Dermatology"
                        android:textSize="13sp"
                        app:chipBackgroundColor="@color/surface_variant"
                        android:textColor="@color/text_secondary"
                        app:chipCornerRadius="20dp"
                        app:chipStrokeColor="@color/divider"
                        app:chipStrokeWidth="1dp"
                        android:layout_marginEnd="8dp"/>

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_general"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="General"
                        android:textSize="13sp"
                        app:chipBackgroundColor="@color/surface_variant"
                        android:textColor="@color/text_secondary"
                        app:chipCornerRadius="20dp"
                        app:chipStrokeColor="@color/divider"
                        app:chipStrokeWidth="1dp"/>

                </LinearLayout>

            </HorizontalScrollView>

            <!-- Available Doctors Count -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginHorizontal="20dp"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Available Doctors"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <TextView
                    android:id="@+id/text_doctors_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="24 doctors"
                    android:textSize="14sp"
                    android:textColor="@color/text_secondary"/>

            </LinearLayout>

            <!-- Doctors RecyclerView -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_doctors"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                android:paddingHorizontal="16dp"
                android:paddingBottom="16dp"/>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- FAB for Filter/Sort -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_filter"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="20dp"
        android:src="@drawable/ic_search"
        app:tint="@color/white"
        app:backgroundTint="@color/primary"
        app:elevation="4dp"
        app:fabSize="normal"
        app:fabCustomSize="56dp"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
