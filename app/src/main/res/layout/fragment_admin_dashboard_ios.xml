<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    android:fillViewport="true"
    android:overScrollMode="never">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header Section with Gradient -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_admin_header_gradient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="20dp"
                android:paddingTop="16dp"
                android:paddingBottom="24dp">

                <!-- Welcome Row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Good morning"
                            android:textSize="14sp"
                            android:textColor="@color/white"
                            android:alpha="0.9"/>

                        <TextView
                            android:id="@+id/text_admin_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Administrator"
                            android:textSize="28sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:letterSpacing="-0.02"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                    <!-- Notification Button -->
                    <ImageButton
                        android:id="@+id/btn_notifications"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:background="@drawable/bg_circle_transparent"
                        android:src="@drawable/ic_notifications"
                        android:contentDescription="Notifications"
                        app:tint="@color/white"
                        android:padding="10dp"/>

                </LinearLayout>

                <!-- Date Display -->
                <TextView
                    android:id="@+id/text_current_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Friday, March 6, 2024"
                    android:textSize="13sp"
                    android:textColor="@color/white"
                    android:alpha="0.8"
                    android:layout_marginTop="8dp"/>

            </LinearLayout>

        </FrameLayout>

        <!-- Main Content - Overlapping Cards -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingHorizontal="16dp"
            android:layout_marginTop="-20dp">

            <!-- Quick Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="16dp">

                <!-- Total Users Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_users_circle"
                            android:background="@drawable/bg_icon_blue_circle"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/stat_total_users"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Total Users"
                            android:textSize="12sp"
                            android:textColor="@color/ios_text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Active Doctors Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_doctor_circle"
                            android:background="@drawable/bg_icon_green_circle"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/stat_active_doctors"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Doctors"
                            android:textSize="12sp"
                            android:textColor="@color/ios_text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Secondary Stats Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginBottom="20dp">

                <!-- Appointments Today Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_calendar_circle"
                            android:background="@drawable/bg_icon_orange_circle"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/stat_appointments_today"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Today's Appts"
                            android:textSize="12sp"
                            android:textColor="@color/ios_text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

                <!-- Pending Verifications Card -->
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="@color/ios_card_background"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="0dp"
                    app:strokeColor="@color/ios_divider"
                    app:strokeWidth="0dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp"
                        android:gravity="center_horizontal">

                        <ImageView
                            android:layout_width="40dp"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_verification_circle"
                            android:background="@drawable/bg_icon_red_circle"
                            android:padding="8dp"/>

                        <TextView
                            android:id="@+id/stat_pending_verifications"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="0"
                            android:textSize="24sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Pending"
                            android:textSize="12sp"
                            android:textColor="@color/ios_text_secondary"
                            android:layout_marginTop="2dp"/>

                    </LinearLayout>

                </com.google.android.material.card.MaterialCardView>

            </LinearLayout>

            <!-- Quick Actions Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Quick Actions"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="12dp"/>

            <!-- Actions Grid Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="0dp"
                android:layout_marginBottom="20dp">

                <GridLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:columnCount="2"
                    android:padding="4dp">

                    <!-- User Management -->
                    <LinearLayout
                        android:id="@+id/action_user_management"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_action_item_selector"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_permissions"
                            android:background="@drawable/bg_action_blue_gradient"
                            android:padding="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Users"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                    <!-- Audit Logs -->
                    <LinearLayout
                        android:id="@+id/action_audit_logs"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_action_item_selector"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_audit_logs"
                            android:background="@drawable/bg_action_green_gradient"
                            android:padding="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Audit Logs"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                    <!-- Analytics -->
                    <LinearLayout
                        android:id="@+id/action_analytics"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_action_item_selector"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_analytics"
                            android:background="@drawable/bg_action_purple_gradient"
                            android:padding="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Analytics"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                    <!-- Partner Portal -->
                    <LinearLayout
                        android:id="@+id/action_partner_portal"
                        android:layout_width="0dp"
                        android:layout_height="100dp"
                        android:layout_columnWeight="1"
                        android:layout_margin="4dp"
                        android:orientation="vertical"
                        android:gravity="center"
                        android:background="@drawable/bg_action_item_selector"
                        android:padding="16dp">

                        <ImageView
                            android:layout_width="48dp"
                            android:layout_height="48dp"
                            android:src="@drawable/ic_partner_portal"
                            android:background="@drawable/bg_action_orange_gradient"
                            android:padding="12dp"/>

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Partners"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/ios_text_primary"
                            android:layout_marginTop="8dp"/>

                    </LinearLayout>

                </GridLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Add Doctor Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Add New Doctor"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="12dp"/>

            <!-- Doctor Form Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="0dp"
                android:layout_marginBottom="20dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <!-- Doctor Name -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Doctor Full Name"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ios_blue"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/ios_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_doctor_name"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPersonName"
                            android:textColor="@color/ios_text_primary"
                            android:textSize="15sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Doctor Email -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Doctor Email"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ios_blue"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/ios_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_doctor_email"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textEmailAddress"
                            android:textColor="@color/ios_text_primary"
                            android:textSize="15sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Specialization -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="Specialization"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ios_blue"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/ios_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_doctor_specialization"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textColor="@color/ios_text_primary"
                            android:textSize="15sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- License Number -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="16dp"
                        android:hint="License Number"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ios_blue"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/ios_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_doctor_license"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="text"
                            android:textColor="@color/ios_text_primary"
                            android:textSize="15sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Password -->
                    <com.google.android.material.textfield.TextInputLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="20dp"
                        android:hint="Set Password"
                        app:boxBackgroundMode="outline"
                        app:boxStrokeColor="@color/ios_blue"
                        app:boxStrokeWidth="1dp"
                        app:boxStrokeWidthFocused="2dp"
                        app:boxCornerRadiusTopStart="12dp"
                        app:boxCornerRadiusTopEnd="12dp"
                        app:boxCornerRadiusBottomStart="12dp"
                        app:boxCornerRadiusBottomEnd="12dp"
                        app:hintTextColor="@color/ios_text_secondary"
                        app:endIconMode="password_toggle"
                        app:endIconTint="@color/ios_text_secondary">

                        <com.google.android.material.textfield.TextInputEditText
                            android:id="@+id/edit_doctor_password"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:inputType="textPassword"
                            android:textColor="@color/ios_text_primary"
                            android:textSize="15sp"/>

                    </com.google.android.material.textfield.TextInputLayout>

                    <!-- Create Doctor Button -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_add_doctor"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:text="Create Doctor Account"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        android:textAllCaps="false"
                        android:letterSpacing="0.02"
                        app:cornerRadius="14dp"
                        app:backgroundTint="@color/ios_blue"
                        android:fontFamily="sans-serif-medium"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Recent Activity Section -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Recent Activity"
                android:textSize="20sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:letterSpacing="-0.01"
                android:layout_marginBottom="12dp"/>

            <!-- Activity List Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="0dp"
                android:layout_marginBottom="24dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_recent_activity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false"
                    android:overScrollMode="never"
                    android:padding="8dp"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Logout Button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_logout"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Logout"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                android:letterSpacing="0.02"
                app:cornerRadius="14dp"
                app:strokeColor="@color/ios_red"
                app:strokeWidth="1.5dp"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:fontFamily="sans-serif-medium"
                android:layout_marginBottom="24dp"/>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
