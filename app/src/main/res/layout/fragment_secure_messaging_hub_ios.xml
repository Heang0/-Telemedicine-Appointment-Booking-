<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    android:fitsSystemWindows="true">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar_layout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_ios_toolbar_gradient"
        android:elevation="0dp"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/ios_page_horizontal_padding"
            android:paddingEnd="@dimen/ios_page_horizontal_padding"
            android:paddingTop="@dimen/ios_header_top_padding"
            android:paddingBottom="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Messages"
                    android:textColor="@color/ios_text_primary"
                    android:textSize="@dimen/ios_header_title_size"
                    android:textStyle="bold" />

                <ImageView
                    android:id="@+id/btn_new_message"
                    android:layout_width="38dp"
                    android:layout_height="38dp"
                    android:background="@drawable/bg_ios_input_field"
                    android:padding="8dp"
                    android:src="@drawable/ic_add"
                    app:tint="@color/ios_text_primary" />

            </LinearLayout>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:text="Secure conversations between patients and clinicians."
                android:textColor="@color/ios_text_secondary"
                android:textSize="14sp" />

            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="18dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    app:boxBackgroundMode="none"
                    app:startIconDrawable="@drawable/ic_search"
                    app:startIconTint="@color/ios_text_secondary">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/edit_search_conversations"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_vertical"
                        android:background="@android:color/transparent"
                        android:hint="Search by name or last message"
                        android:paddingTop="10dp"
                        android:paddingBottom="10dp"
                        android:textColor="@color/ios_text_primary"
                        android:textSize="15sp" />

                </com.google.android.material.textfield.TextInputLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </com.google.android.material.appbar.AppBarLayout>

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_messages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:cardBackgroundColor="@color/ios_card_background"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior"
        app:strokeColor="@color/ios_divider"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <HorizontalScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="16dp"
                android:paddingTop="12dp"
                android:paddingBottom="10dp"
                android:scrollbars="none">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="All"
                        android:textSize="12sp"
                        app:chipBackgroundColor="@color/ios_blue"
                        app:chipCornerRadius="16dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_unread"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Unread"
                        android:textSize="12sp"
                        app:chipBackgroundColor="@color/ios_system_fill"
                        app:chipCornerRadius="16dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_doctors"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginEnd="8dp"
                        android:text="Doctors"
                        android:textSize="12sp"
                        app:chipBackgroundColor="@color/ios_system_fill"
                        app:chipCornerRadius="16dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_patients"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patients"
                        android:textSize="12sp"
                        app:chipBackgroundColor="@color/ios_system_fill"
                        app:chipCornerRadius="16dp" />

                </LinearLayout>

            </HorizontalScrollView>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/ios_divider" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_conversations"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:clipToPadding="false"
                android:overScrollMode="never"
                android:paddingStart="14dp"
                android:paddingTop="14dp"
                android:paddingEnd="14dp"
                android:paddingBottom="24dp" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
