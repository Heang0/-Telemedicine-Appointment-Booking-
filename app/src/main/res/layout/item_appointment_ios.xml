<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Appointment Item Card (Enhanced) -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/ios_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ios_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Left Blue Accent Bar -->
        <View
            android:layout_width="4dp"
            android:layout_height="match_parent"
            android:background="@color/ios_blue"
            android:minHeight="80dp"/>

        <!-- Time Column -->
        <LinearLayout
            android:layout_width="68dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:paddingHorizontal="8dp">

            <TextView
                android:id="@+id/text_appointment_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="9:00"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/ios_blue"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/text_appointment_ampm"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AM"
                android:textSize="11sp"
                android:textColor="@color/ios_text_secondary"
                android:fontFamily="sans-serif-medium"
                android:layout_marginTop="2dp"/>

        </LinearLayout>

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:minHeight="80dp"
            android:background="@color/ios_divider"/>

        <!-- Content Column -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="14dp">

            <TextView
                android:id="@+id/text_patient_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Patient Name"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:fontFamily="sans-serif-medium"/>

            <TextView
                android:id="@+id/text_appointment_type"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Consultation"
                android:textSize="13sp"
                android:textColor="@color/ios_text_secondary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="4dp"/>

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="6dp">

                <ImageView
                    android:layout_width="13dp"
                    android:layout_height="13dp"
                    android:src="@drawable/ic_video_call_24"
                    app:tint="@color/ios_blue"/>

                <TextView
                    android:id="@+id/text_appointment_mode"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Video Call"
                    android:textSize="12sp"
                    android:textColor="@color/ios_blue"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="4dp"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Status Badge -->
        <TextView
            android:id="@+id/text_appointment_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Upcoming"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/ios_blue"
            android:fontFamily="sans-serif-medium"
            android:background="@drawable/bg_status_badge_ios"
            android:paddingHorizontal="10dp"
            android:paddingVertical="5dp"
            android:layout_marginEnd="14dp"/>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
