<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Prescription List Item -->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/ios_card_background"
    app:cardCornerRadius="18dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ios_divider"
    app:strokeWidth="1dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header Row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/text_medication_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Amoxicillin 500mg"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:textColor="@color/ios_text_primary"
                    android:fontFamily="sans-serif-medium"/>

                <TextView
                    android:id="@+id/text_patient_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Patient: John Doe"
                    android:textSize="13sp"
                    android:textColor="@color/ios_text_secondary"
                    android:fontFamily="sans-serif"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/text_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Active"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/ios_green"
                android:background="@drawable/bg_status_badge_ios"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"/>

        </LinearLayout>

        <!-- Dosage Info -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@drawable/ic_medication_24"
                app:tint="@color/ios_text_secondary"/>

            <TextView
                android:id="@+id/text_dosage"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="1 tablet every 8 hours"
                android:textSize="14sp"
                android:textColor="@color/ios_text_primary"
                android:fontFamily="sans-serif"
                android:layout_marginStart="10dp"/>

        </LinearLayout>

        <!-- Duration & Prescribed By -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="10dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_calendar"
                    app:tint="@color/ios_text_secondary"/>

                <TextView
                    android:id="@+id/text_duration"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="7 days"
                    android:textSize="13sp"
                    android:textColor="@color/ios_text_secondary"
                    android:fontFamily="sans-serif"
                    android:layout_marginStart="8dp"/>

            </LinearLayout>

            <TextView
                android:id="@+id/text_prescribed_by"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Dr. Smith"
                android:textSize="13sp"
                android:textColor="@color/ios_blue"
                android:fontFamily="sans-serif-medium"/>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
