<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@color/ai_neutral_50">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Modern AI Design Test"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/ai_neutral_900"
        android:layout_marginBottom="24dp"
        android:gravity="center" />

    <!-- Test Card -->
    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="16dp"
        app:cardElevation="4dp"
        app:strokeColor="@color/ai_neutral_200"
        app:strokeWidth="1dp"
        app:backgroundTint="@color/card_background_light"
        android:layout_marginBottom="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="AI Health Assistant"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/ai_neutral_900"
                android:layout_marginBottom="12dp" />

            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="This is a test of the modern AI-inspired design system. The interface features:"
                android:textSize="16sp"
                android:textColor="@color/ai_neutral_700"
                android:layout_marginBottom="16dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check_circle_24"
                    android:tint="@color/success"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Modern Material 3 styling with AI-inspired colors"
                    android:textSize="14sp"
                    android:textColor="@color/ai_neutral_900" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check_circle_24"
                    android:tint="@color/success"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Glassmorphism effects and subtle gradients"
                    android:textSize="14sp"
                    android:textColor="@color/ai_neutral_900" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_check_circle_24"
                    android:tint="@color/success"
                    android:layout_marginEnd="8dp" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Responsive design for all screen sizes"
                    android:textSize="14sp"
                    android:textColor="@color/ai_neutral_900" />

            </LinearLayout>

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- Test Button -->
    <Button
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Test Modern Button"
        android:textSize="16sp"
        android:padding="16dp"
        style="@style/Widget.Telemedicine.Button"
        android:backgroundTint="@color/ai_gradient_start"
        android:textColor="@color/text_on_surface"
        android:layout_marginTop="16dp" />

</LinearLayout>
