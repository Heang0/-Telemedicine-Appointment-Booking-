<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="4dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/ios_card_background"
    app:cardCornerRadius="16dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ios_divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Patient Avatar -->
        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/image_patient_avatar"
            android:layout_width="50dp"
            android:layout_height="50dp"
            android:src="@drawable/ic_profile"
            app:civ_border_width="2dp"
            app:civ_border_color="@color/ios_divider"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Patient Name -->
        <TextView
            android:id="@+id/text_patient_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="John Smith"
            android:textSize="17sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary"
            android:layout_marginStart="12dp"
            app:layout_constraintTop_toTopOf="@id/image_patient_avatar"
            app:layout_constraintStart_toEndOf="@id/image_patient_avatar"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Patient Age & Gender -->
        <TextView
            android:id="@+id/text_patient_info"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="32 years • Male"
            android:textSize="14sp"
            android:textColor="@color/ios_text_secondary"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/text_patient_name"
            app:layout_constraintStart_toEndOf="@id/image_patient_avatar"/>

        <!-- Last Visit Label -->
        <TextView
            android:id="@+id/label_last_visit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Last Visit"
            android:textSize="12sp"
            android:textColor="@color/ios_text_secondary"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/image_patient_avatar"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Last Visit Date -->
        <TextView
            android:id="@+id/text_last_visit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jan 15, 2024"
            android:textSize="13sp"
            android:textStyle="bold"
            android:textColor="@color/ios_text_primary"
            android:layout_marginTop="2dp"
            app:layout_constraintTop_toBottomOf="@id/label_last_visit"
            app:layout_constraintStart_toStartOf="parent"/>

        <!-- Medical History Label -->
        <TextView
            android:id="@+id/label_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Medical History"
            android:textSize="12sp"
            android:textColor="@color/ios_text_secondary"
            android:layout_marginTop="12dp"
            app:layout_constraintTop_toBottomOf="@id/image_patient_avatar"
            app:layout_constraintEnd_toEndOf="parent"/>

        <!-- Medical History Tags -->
        <LinearLayout
            android:id="@+id/layout_history_tags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="end"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@id/label_history"
            app:layout_constraintStart_toStartOf="@id/label_history"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/text_history_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diabetes"
                android:textSize="12sp"
                android:textColor="@color/ios_blue"
                android:background="@drawable/bg_history_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"/>

            <TextView
                android:id="@+id/text_history_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Hypertension"
                android:textSize="12sp"
                android:textColor="@color/ios_orange"
                android:background="@drawable/bg_history_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:layout_marginStart="6dp"/>

        </LinearLayout>

        <!-- View Profile Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_profile"
            style="@style/Widget.Telemedicine.Button.Filled"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:text="View Profile"
            android:textSize="14sp"
            android:layout_marginTop="16dp"
            app:layout_constraintTop_toBottomOf="@id/text_last_visit"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
