<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="2dp"
    android:layout_marginVertical="5dp"
    app:cardBackgroundColor="@color/ios_card_background"
    app:cardCornerRadius="22dp"
    app:cardElevation="0dp"
    app:strokeColor="@color/ios_divider"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingStart="15dp"
        android:paddingTop="15dp"
        android:paddingEnd="15dp"
        android:paddingBottom="15dp">

        <de.hdodenhof.circleimageview.CircleImageView
            android:id="@+id/image_patient_avatar"
            android:layout_width="54dp"
            android:layout_height="54dp"
            android:src="@drawable/ic_profile"
            app:civ_border_color="@color/ios_divider"
            app:civ_border_width="2dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/text_patient_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="10dp"
            android:text="John Smith"
            android:textColor="@color/ios_text_primary"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btn_view_profile"
            app:layout_constraintStart_toEndOf="@id/image_patient_avatar"
            app:layout_constraintTop_toTopOf="@id/image_patient_avatar" />

        <TextView
            android:id="@+id/text_patient_info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:layout_marginEnd="10dp"
            android:text="32 years • Male"
            android:textColor="@color/ios_text_secondary"
            android:textSize="13sp"
            app:layout_constraintEnd_toStartOf="@id/btn_view_profile"
            app:layout_constraintStart_toEndOf="@id/image_patient_avatar"
            app:layout_constraintTop_toBottomOf="@id/text_patient_name" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_view_profile"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:minWidth="0dp"
            android:text="Open"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="@color/ios_blue"
            app:cornerRadius="18dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@id/image_patient_avatar" />

        <TextView
            android:id="@+id/label_last_visit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Last Visit"
            android:textColor="@color/ios_text_secondary"
            android:textSize="11sp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image_patient_avatar" />

        <TextView
            android:id="@+id/label_history"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="Profile Tags"
            android:textColor="@color/ios_text_secondary"
            android:textSize="11sp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/image_patient_avatar" />

        <TextView
            android:id="@+id/text_last_visit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Jan 15, 2024"
            android:textColor="@color/ios_text_primary"
            android:textSize="13sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/label_last_visit" />

        <LinearLayout
            android:id="@+id/layout_history_tags"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:gravity="end"
            android:orientation="horizontal"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="@id/label_last_visit"
            app:layout_constraintTop_toBottomOf="@id/label_history">

            <TextView
                android:id="@+id/text_history_1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_history_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Diabetes"
                android:textColor="@color/ios_blue"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/text_history_2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:background="@drawable/bg_history_tag"
                android:paddingHorizontal="10dp"
                android:paddingVertical="4dp"
                android:text="Hypertension"
                android:textColor="@color/ios_orange"
                android:textSize="11sp" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
