<?xml version="1.0" encoding="utf-8"?>
<!-- iOS-Style Patient EMR (Electronic Medical Record) -->
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ios_background"
    android:fillViewport="true"
    android:fitsSystemWindows="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="24dp">

        <!-- iOS-Style Header -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_ios_gradient_header_patient">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp"
                android:paddingTop="@dimen/ios_header_top_padding">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Medical Records"
                    android:textSize="@dimen/ios_header_title_size"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:fontFamily="sans-serif"
                    android:letterSpacing="-0.02"
                    android:maxLines="1"
                    android:ellipsize="end"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Your complete health history"
                    android:textSize="15sp"
                    android:textColor="@color/white"
                    android:alpha="0.85"
                    android:layout_marginTop="4dp"/>

            </LinearLayout>

        </FrameLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingStart="@dimen/ios_page_horizontal_padding"
            android:paddingEnd="@dimen/ios_page_horizontal_padding"
            android:layout_marginTop="-20dp">

            <!-- Patient Info Card -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="20dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <de.hdodenhof.circleimageview.CircleImageView
                            android:id="@+id/profile_image"
                            android:layout_width="56dp"
                            android:layout_height="56dp"
                            android:src="@drawable/ic_profile"
                            app:civ_border_width="3dp"
                            app:civ_border_color="@color/ios_blue"/>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical"
                            android:layout_marginStart="16dp">

                            <LinearLayout
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:orientation="horizontal"
                                android:gravity="center_vertical">

                                <TextView
                                    android:id="@+id/text_patient_name"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:layout_weight="1"
                                    android:text="John Doe"
                                    android:textSize="20sp"
                                    android:textStyle="bold"
                                    android:textColor="@color/ios_text_primary"
                                    android:fontFamily="sans-serif-medium"
                                    android:maxLines="1"
                                    android:ellipsize="end"/>

                                <ImageView
                                    android:id="@+id/btn_edit_patient_info"
                                    android:layout_width="32dp"
                                    android:layout_height="32dp"
                                    android:src="@drawable/ic_person_24"
                                    android:padding="4dp"
                                    app:tint="@color/ios_blue"
                                    android:layout_marginStart="8dp"
                                    android:contentDescription="Edit patient info"/>

                            </LinearLayout>

                            <TextView
                                android:id="@+id/text_patient_mrn"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="MRN: 123456789"
                                android:textSize="14sp"
                                android:textColor="@color/ios_text_secondary"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <ImageView
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:src="@drawable/ic_document"
                            app:tint="@color/ios_blue"/>

                    </LinearLayout>

                    <!-- Info Grid -->
                    <GridLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:columnCount="2"
                        android:rowCount="2"
                        android:layout_marginTop="20dp">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:background="@drawable/bg_ios_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Date of Birth"
                                android:textSize="12sp"
                                android:textColor="@color/ios_text_secondary"/>

                            <TextView
                                android:id="@+id/text_patient_dob"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Jan 1, 1980"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/ios_text_primary"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:background="@drawable/bg_ios_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Gender"
                                android:textSize="12sp"
                                android:textColor="@color/ios_text_secondary"/>

                            <TextView
                                android:id="@+id/text_patient_gender"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Male"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/ios_text_primary"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="8dp"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:background="@drawable/bg_ios_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Blood Type"
                                android:textSize="12sp"
                                android:textColor="@color/ios_text_secondary"/>

                            <TextView
                                android:id="@+id/text_blood_type"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="O+"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/ios_text_primary"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_columnWeight="1"
                            android:layout_marginTop="8dp"
                            android:layout_marginStart="8dp"
                            android:orientation="vertical"
                            android:padding="12dp"
                            android:background="@drawable/bg_ios_input_field">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Primary Care"
                                android:textSize="12sp"
                                android:textColor="@color/ios_text_secondary"/>

                            <TextView
                                android:id="@+id/text_primary_care"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Dr. Smith"
                                android:textSize="16sp"
                                android:textStyle="bold"
                                android:textColor="@color/ios_text_primary"
                                android:layout_marginTop="4dp"/>

                        </LinearLayout>

                    </GridLayout>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Section Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Medical History"
                android:textSize="@dimen/ios_section_title_size"
                android:textStyle="bold"
                android:textColor="@color/ios_text_primary"
                android:fontFamily="sans-serif"
                android:layout_marginTop="24dp"
                android:layout_marginBottom="14dp"/>

            <!-- Medical History List -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardBackgroundColor="@color/ios_card_background"
                app:cardCornerRadius="20dp"
                app:cardElevation="0dp"
                app:strokeColor="@color/ios_divider"
                app:strokeWidth="1dp">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recycler_medical_history"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:clipToPadding="false"
                    android:padding="16dp"
                    android:overScrollMode="never"/>

            </com.google.android.material.card.MaterialCardView>

            <!-- Action Buttons -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:layout_marginTop="20dp">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_share_records"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Share Records"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/ios_card_background"
                    app:strokeColor="@color/ios_blue"
                    app:strokeWidth="2dp"
                    app:cornerRadius="14dp"
                    android:layout_marginEnd="8dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_download_records"
                    android:layout_width="0dp"
                    android:layout_height="52dp"
                    android:layout_weight="1"
                    android:text="Download"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    app:backgroundTint="@color/ios_blue"
                    app:cornerRadius="14dp"
                    android:layout_marginStart="8dp"
                    app:icon="@drawable/ic_document"
                    app:iconGravity="textStart"/>

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</androidx.core.widget.NestedScrollView>
